<Page x:Class="CRM.Pages.PageClients"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CRM.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page_login" Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DataGrid_User" 
              Grid.Row="2" Grid.RowSpan ="3"
              Grid.Column="1" Grid.ColumnSpan ="3"
              ItemsSource="{Binding ListClients}"
              AutoGenerateColumns="False" 
               CanUserAddRows="False" CanUserDeleteRows="False"
             >
            <DataGrid.Columns >
                <DataGridTextColumn x:Name="DG_Name" Header="Имя"
                                    Binding="{Binding FirstName}" 
                                    Width="*"/>
                <DataGridTextColumn x:Name="DG_Patronymic" Header="Отчество"
                                    Binding="{Binding MiddleName}"
                                    Width="*"/>
                <DataGridTextColumn x:Name="DG_FName" Header="Фамилия"
                                    Binding="{Binding LastName}"
                                    Width="*"/>
                <DataGridTextColumn x:Name="DG_Phone" Header="Телефон"
                                    Binding="{Binding PhoneNumber}"
                                    Width="*"/>
            </DataGrid.Columns>


        </DataGrid>
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Button x:Name="bt_AddClient" Content="Добавить" 
                Grid.Column="0" Grid.Row="2" 
                Width="auto" Height="auto"
                HorizontalAlignment="Stretch"  VerticalAlignment="Stretch"
                Command="{Binding AddClient}"/>

            <Button x:Name="bt_DeleteClient" Content="Удалить" 
                Grid.Column="2" Grid.Row="2" 
                Width="auto" Height="auto"
                HorizontalAlignment="Stretch"  VerticalAlignment="Stretch"
                Command="{Binding DeleteClient}"/>

        </Grid>


    </Grid>

</Page>
