<Window x:Class="CRM.Windows.NewClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM.Windows"
        mc:Ignorable="d"
        Title="Новый клиент" MinHeight="300" MinWidth="250" >
    <Grid ShowGridLines="False"
          Background="#1e2248" Margin="0,0,0,-6" >
        <!--Сетка-->
        <!--#region -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!--#endregion-->

        <Label x:Name="lb_heading" 
                 Grid.Column="0" Grid.Row="0" 
                 Grid.ColumnSpan="5"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Margin="0,0,0,0" Content="Создание клиента" Foreground="White" FontSize="20" />

        <Label x:Name="lb_Name" 
                 Grid.Column="0" Grid.Row="1" 
                 Grid.ColumnSpan="2"
                 HorizontalAlignment="Stretch" VerticalAlignment="Center"
                 Margin="5,5,5,0" Content="Имя" Foreground="White" />

        <TextBox x:Name="tb_Name" 
                 Grid.Column="2" Grid.Row="1" 
                 Grid.ColumnSpan="3" VerticalAlignment="Stretch"
                 Margin="5,15,10,15" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />


        <Label x:Name="lb_fName" 
                 Grid.Column="0" Grid.Row="2" 
                 Grid.ColumnSpan="2"
                 HorizontalAlignment="Stretch" VerticalAlignment="Center"
                 Margin="5,5,5,0" Content="Фамилия" Foreground="White" />


        <TextBox x:Name="tb_fName" 
                Grid.Column="2" Grid.Row="2" 
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Margin="5,15,10,15" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />


        <Label x:Name="lb_tName" 
                Grid.Column="0" Grid.Row="3" 
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Margin="5,5,5,0" Content="Отчество" Foreground="White" />


        <TextBox x:Name="tb_tName" 
                Grid.Column="2" Grid.Row="3" 
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Margin="5,15,10,15" Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" />

        <Label x:Name="lb_fhone" 
                Grid.Column="0" Grid.Row="4" 
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Margin="5,5,5,0" Content="Номер телефона" Foreground="White" />
        
        <TextBox x:Name="tb_fhone" 
                Grid.Column="2" Grid.Row="4" 
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Margin="5,15,10,15" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" UndoLimit="10" />

        <StackPanel Grid.Column="2" Grid.Row="5" 
Grid.ColumnSpan="3"/>

        <Button x:Name="bt_enter" Content="Создать"
                Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Margin="5,15,5,15"  Command="{Binding AddClient}"/>


    </Grid>
</Window>
